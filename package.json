{
  "name": "@narthia/openapi-sdk-generator",
  "version": "0.1.0",
  "description": "OpenAPI SDK Generator",
  "keywords": [
    "code-generation",
    "codegen",
    "narthia",
    "openapi",
    "openapi-generator",
    "rest",
    "rest-api",
    "sdk",
    "sdk-generator",
    "swagger",
    "typescript"
  ],
  "homepage": "https://github.com/narthia/openapi-sdk-generator#readme",
  "bugs": {
    "url": "https://github.com/narthia/openapi-sdk-generator/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Jeevan Karnati",
    "email": "jeevanreddy1999@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/narthia/openapi-sdk-generator.git"
  },
  "bin": {
    "openapi-sdk-generator": "./dist/cli/index.mjs"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./dist/index.mjs",
    "./cli": "./dist/cli/index.mjs",
    "./client": "./dist/client/index.mjs",
    "./transports/http": "./dist/transports/http/index.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "changeset": "changeset",
    "changeset:publish": "changeset publish",
    "changeset:version": "changeset version",
    "check": "vp check",
    "check:fix": "vp check --fix",
    "dev": "vp pack --watch",
    "prepublishOnly": "vp run check && vp run build",
    "test": "vp test"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.1",
    "@narthia/toolkit": "^0.0.4",
    "@types/node": "^26.1.1",
    "eslint-plugin-check-file": "^3.3.2",
    "oxfmt": "^0.60.0",
    "oxlint": "^1.75.0",
    "typescript": "5.9.3",
    "vite": "npm:@voidzero-dev/vite-plus-core@0.2.6",
    "vite-plus": "^0.2.6"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "bun@1.3.14"
}
